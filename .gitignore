# memory plugin gitignore.

# Local override of committed profiles (.env.local / .env.azuredev).
# Useful for stashing a real MEMORY_API_KEY or Clerk credentials without
# touching tracked files.
.env

# Node / Bun artifacts.
node_modules/
.bun/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Anything matching Clerk cached creds -- defensive in case a user copies
# their auth.json into the plugin root.
auth.json

# Claude Code session noise (logs, state, transient marker dirs).
.claude/logs/
.claude/state/
.in_use/

# Local git worktrees + orphan markers (transient; never commit the nested checkout).
.claude/worktrees/
.orphaned_at

# crew:start
# Crew framework local state. Generated; do not edit between markers.
.claude/logs/
.claude/state/crew/history.jsonl
.claude/state/crew/approvals.jsonl
.claude.backup.*
# crew:end
