# memory plugin -- example env profile.
#
# Copy to `.env.local` (untracked; see .gitignore) and fill in real values.
# Superseded by the unified config dir as of v0.5.0+ (see README "Unified
# config directory" + "Environment variables") -- most of these are picked up
# automatically via secrets.env / config.json written by `astramem connect`.
# This file remains for hook scripts and any shell profile that still wants
# to export vars directly.

# --- Provider selector -------------------------------------------------------
# ASTRAMEM_PROVIDER=auto            # local | saas | auto

# --- Local daemon (default profile) -----------------------------------------
MEMORY_API_URL_LOCAL=http://127.0.0.1:7777
# MEMORY_BEARER=                    # written to secrets.env by `astramem connect`; do not commit a real value here

# --- SaaS gateway (set only if using provider=saas) -------------------------
# MEMORY_API_URL_SAAS=https://<your-saas-host>/api

# --- Transcript-capture hook turn/char caps ---------------------------------
MEMORY_PRECOMPACT_MAX_TURNS=20
MEMORY_PRECOMPACT_MAX_CHARS=12000
MEMORY_SESSIONEND_MAX_TURNS=40
MEMORY_SESSIONEND_MAX_CHARS=20000
MEMORY_SUBAGENT_MAX_TURNS=20
MEMORY_SUBAGENT_MAX_CHARS=12000
